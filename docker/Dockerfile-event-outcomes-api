# Stage 1: Build
FROM maven:3.9.3-eclipse-temurin-17 AS build
WORKDIR /app

COPY . .

# Build shared libraries first (monorepo support)
RUN mvn -pl libs/dto/common-dto,libs/domain/common-domain clean install -DskipTests

# Build API module
RUN mvn -pl api/event-outcomes-api -am clean package -DskipTests

# Extract Spring Boot layers into a fixed location
RUN mkdir -p /layers && \
    java -Djarmode=layertools \
    -jar api/event-outcomes-api/target/*.jar \
    extract --destination /layers


# Stage 2: Runtime
FROM eclipse-temurin:17-jdk-jammy
WORKDIR /app

# Copy extracted layers (IMPORTANT: correct structure)
COPY --from=build /layers/dependencies/ ./dependencies/
COPY --from=build /layers/spring-boot-loader/ ./spring-boot-loader/
COPY --from=build /layers/snapshot-dependencies/ ./snapshot-dependencies/
COPY --from=build /layers/application/ ./application/

# Expose Spring Boot port (adjust if needed)
EXPOSE 8080

# Use correct Spring Boot launcher
ENTRYPOINT ["java", "org.springframework.boot.loader.JarLauncher"]